  const m6=[];for(let i=5;i>=0;i--){const dt=new Date(n);dt.setMonth(dt.getMonth()-i);m6.push({M:mp(dt.getMonth(),dt.getFullYear()),l:MO[dt.getMonth()]});}
  drawC('hb-ch',m6.map(x=>({l:x.l,v:d.readings.filter(r=>r.date.startsWith(x.M)).reduce((s,r)=>s+r.hk,0)})),65,'var(--hb)');
