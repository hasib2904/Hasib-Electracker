};
window.parseAI=async function(){
  const txt=v('ait');if(!txt){toast('Enter description','err');return;}
  const pip=document.getElementById('aipp');pip.style.display='block';pip.textContent='🤖 Parsing...';pip.style.color='var(--hb)';
  document.getElementById('aipb').disabled=true;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:`Parse appliances from: "${txt}"\nReturn ONLY valid JSON array, no markdown. Each: name, icon(emoji), watts(number), hours(per day), duty(1-100), category(Cooling/Lighting/Refrigeration/Entertainment/Kitchen/Other).`}]})});
    const data=await res.json();
    _pa=JSON.parse((data.content[0]?.text||'').replace(/```json|```/g,'').trim());
    document.getElementById('aiprev').innerHTML=_pa.map(a=>`<div class="ai2" style="margin-bottom:6px"><div class="ai-em">${a.icon}</div><div class="ai-info"><div class="ai-name">${a.name}</div><div class="ai-det">${a.watts}W · ${a.hours}h · ${a.duty}%</div></div><span class="badge bg">NEW</span></div>`).join('');
    pip.textContent=`✅ Found ${_pa.length} appliances`;pip.style.color='var(--gr)';
    document.getElementById('aicb').style.display='inline-flex';
  }catch(e){pip.textContent='⚠️ Failed — try rephrasing';pip.style.color='var(--rd)';}
  document.getElementById('aipb').disabled=false;
};
window.confirmAI=async function(){
  const own=v('aiao');const d=D();const list=own==='h'?d.hAppl:d.nAppl;
  _pa.forEach(a=>list.push({id:Date.now()+Math.random()*999|0,name:a.name,icon:a.icon,watts:a.watts,hours:a.hours,duty:a.duty,cat:a.category,common:false,own}));
  window.closeS('sh-ai');
  renderAll();
  toast(`Added ${_pa.length} appliances ✅`);
  await pushToDB(d);
