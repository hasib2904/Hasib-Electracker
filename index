// ===== EXPORT PRE-FILLED APP =====
window.exportApp=function(){
  const cfg=getCfg();
  if(!cfg){toast('No Firebase config to embed','err');return;}
  let src=document.documentElement.outerHTML;
  // inject config as auto-fill
  const inject=`<script>window.addEventListener('DOMContentLoaded',function(){const c=${JSON.stringify(cfg)};['cfg-apikey','cfg-auth','cfg-dburl','cfg-projid','cfg-appid'].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.value=[c.apiKey,c.authDomain,c.databaseURL,c.projectId,c.appId][i];});});<\/script>`;
  src=src.replace('</head>',inject+'</head>');
  const b=new Blob([src],{type:'text/html'});const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='ElecTracker_prefilled.html';a.click();
  toast('Pre-filled file exported! Share this with family 📤');
