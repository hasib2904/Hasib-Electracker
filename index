async function initFirebase(cfg){
  try{
    const {initializeApp,getApps} = await import('https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js');
    const {getDatabase,ref,onValue,set,get} = await import('https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js');
    if(getApps().length===0) _fbApp = initializeApp(cfg);
    else _fbApp = getApps()[0];
    _db = getDatabase(_fbApp);
    window._fbRef = ref;
    window._fbOnValue = onValue;
    window._fbSet = set;
    window._fbGet = get;
    window._fbDB = _db;
    // test connection
    const testRef = ref(_db,'__ping__');
    await set(testRef, Date.now());
    setSyncDot(true);
    setupRealtimeListener();
    return true;
  }catch(e){
    console.error('Firebase init error:',e);
    setSyncDot(false);
    return false;
  }
}

function setupRealtimeListener(){
  if(!_db) return;
  const r = window._fbRef(_db,'electracker');
  window._fbOnValue(r, snap=>{
    const val = snap.val();
    // val is null when DB is empty (first launch) — init fresh
    _D = val || loadLocal() || freshDB();
    // normalise every array field (Firebase stores arrays as objects keyed by id)
    ['readings','topups','sessions','nbpay','hAppl','nAppl'].forEach(k=>{
      if(!_D[k]) _D[k]=[];
      else if(typeof _D[k]==='object' && !Array.isArray(_D[k])) _D[k]=Object.values(_D[k]);
    });
    if(!_D.hAppl||!_D.hAppl.length) _D.hAppl = defAppl('h');
    if(!_D.nAppl||!_D.nAppl.length) _D.nAppl = defAppl('n');
    if(!_D.nbName) _D.nbName = 'Neighbor';
    if(!_D.lastTop) _D.lastTop = 0;
    saveLocal(_D);
    renderAll();
    setSyncDot(true);
  }, err=>{
    console.error('Firebase listener error:',err);
    setSyncDot(false);
  });
}

async function pushToDB(data){
  if(_localMode||!_db){saveLocal(data);return;}
  try{
    // convert arrays to objects for firebase
    // deep clone so we don't mutate _D when converting arrays→objects
  const payload = JSON.parse(JSON.stringify(data));
  ['readings','topups','sessions','nbpay','hAppl','nAppl'].forEach(k=>{
    if(Array.isArray(payload[k])){
      const obj={};
      payload[k].forEach((item,i)=>{obj[item.id||i]=item;});
      payload[k]=obj;
    }
  });
    await window._fbSet(window._fbRef(_db,'electracker'), payload);
    setSyncDot(true);
  }catch(e){
    console.error('Firebase write error:',e);
    setSyncDot(false);
    saveLocal(data);
    toast('Saved locally — sync failed','err');
  }
}

function saveLocal(d){localStorage.setItem(DK,JSON.stringify(d));}
