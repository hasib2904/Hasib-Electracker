// ===== HOME =====
function rHome(){
  const d=D();if(!d)return;
  const n=new Date(),M=mp(n.getMonth(),n.getFullYear());
  const sr=d.readings.slice().sort((a,b)=>b.date.localeCompare(a.date));
  if(sr.length){
    const lat=sr[0];
    const balEl=document.getElementById('h-bal');
    balEl.textContent='৳ '+f(lat.bal,2);
    const lt=d.lastTop||d.topups[0]?.amt||0;
    const pct=lt>0?Math.min(100,Math.round(lat.bal/lt*100)):50;
    balEl.style.color=pct>50?'var(--t1)':pct>20?'var(--nb)':'var(--rd)';
    document.getElementById('h-kwh').textContent=`≈ ${f(uFromT(lat.bal),1)} kWh remaining`;
    document.getElementById('h-lr').textContent='Last: '+fD(lat.date);
    document.getElementById('h-bar').style.width=pct+'%';
    document.getElementById('h-bar').style.background=pct>50?'linear-gradient(90deg,var(--hb),var(--cy))':pct>20?'linear-gradient(90deg,var(--nb),var(--nb2))':'linear-gradient(90deg,var(--rd),var(--nb))';
    document.getElementById('h-pct').textContent=pct+'% remaining';
  }else{
    const balEl=document.getElementById('h-bal');
    balEl.textContent='৳ 0.00';balEl.style.color='var(--t3)';
    document.getElementById('h-kwh').textContent='Tap Log to add first reading';
    document.getElementById('h-lr').textContent='—';document.getElementById('h-pct').textContent='—';
  }
  const mR=d.readings.filter(r=>r.date.startsWith(M));
  const hU=mR.reduce((s,r)=>s+r.hk,0),nU=mR.reduce((s,r)=>s+r.nk,0),tU=hU+nU;
  const tB=calcBill(tU).total,hs=tU>0?hU/tU:0.5,ns=1-hs;
  document.getElementById('sp-hu').textContent=f(hU,1)+' kWh';document.getElementById('sp-nu').textContent=f(nU,1)+' kWh';
  document.getElementById('sp-hb').textContent='৳'+f(tB*hs,0);document.getElementById('sp-nb2').textContent='৳'+f(tB*ns,0);
  const nn=d.nbName||'Neighbor';
  document.getElementById('sp-nn').textContent='🏘️ '+nn;
  const hp=Math.round(hs*100);
  document.getElementById('sp-bar').children[0].style.width=hp+'%';document.getElementById('sp-bar').children[1].style.width=(100-hp)+'%';
  const tnbB=d.readings.reduce((s,r)=>{const t=r.hk+r.nk;return s+calcBill(t).total*(t>0?r.nk/t:0);},0);
  const tpd=d.nbpay.reduce((s,p)=>s+p.amt,0),owed=Math.max(0,tnbB-tpd);
  if(owed>0){document.getElementById('owcard').style.display='flex';document.getElementById('ow-amt').textContent='৳ '+f(owed,0);document.getElementById('ow-sub').textContent=`৳${f(tpd,0)} paid · ৳${f(tnbB,0)} total`;}
  else document.getElementById('owcard').style.display='none';
  const com=d.hAppl.filter(a=>a.common);
  if(com.length){document.getElementById('qw').style.display='';document.getElementById('qg').innerHTML=com.map(a=>`<div class="qbtn" onclick="qLog(${a.id})"><div class="qi">${a.icon}</div><div class="qn">${a.name}</div><div class="qk">${f(dkwh(a),3)} kWh/day</div></div>`).join('');}
  else document.getElementById('qw').style.display='none';
  const d7=[];for(let i=6;i>=0;i--){const dt=new Date(n);dt.setDate(dt.getDate()-i);d7.push(dt.toISOString().split('T')[0]);}
  drawC('wk-ch',d7.map((dt,i)=>({l:new Date(dt).toLocaleDateString('en-GB',{weekday:'short'}),v:d.readings.filter(r=>r.date===dt).reduce((s,r)=>s+r.hk+r.nk,0)})),65,'var(--hb)');
  const all=[...d.readings.map(r=>({...r,_t:'r'})),...d.topups.map(t=>({...t,_t:'t'})),...d.nbpay.map(p=>({...p,_t:'p'}))].sort((a,b)=>b.date.localeCompare(a.date)).slice(0,5);
  document.getElementById('h-rec').innerHTML=all.length?all.map(e=>liHTML(e)).join(''):`<div class="empty"><div class="empty-ic">⚡</div><div>No data yet. Tap Log to start!</div></div>`;
}
window.qLog=async function(id){
  const d=D();const a=d.hAppl.find(x=>x.id===id);if(!a)return;
  const k=+(dkwh(a)).toFixed(3);
  d.sessions.push({id:Date.now(),date:tod(),appl:[a.name],kwh:k,cost:+(k*10).toFixed(2),min:Math.round(a.hours*60)});
  renderAll();
  toast(`${a.name} logged ✅`);
  await pushToDB(d);
};

// ===== HASIB =====
function rHasib(){
  const d=D();if(!d)return;
  const n=new Date(),M=mp(n.getMonth(),n.getFullYear());
  const mR=d.readings.filter(r=>r.date.startsWith(M));
  const hU=mR.reduce((s,r)=>s+r.hk,0),nU=mR.reduce((s,r)=>s+r.nk,0),tU=hU+nU;
