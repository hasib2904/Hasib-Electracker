const blob = new Blob([JSON.stringify(manifest)], {type:'application/json'});
document.getElementById('pwa-manifest').href = URL.createObjectURL(blob);
</script>
<title>ElecTracker — by Hasib</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
:root{
  --bg:#0a0e1a;--bg2:#0f1525;--s1:#141c2e;--s2:#1a2440;--s3:#1e2a4a;
  --bd:#1e2d4a;--bd2:#263660;
  --hb:#3b82f6;--hb2:#60a5fa;--hbg:rgba(59,130,246,0.13);
  --nb:#f59e0b;--nb2:#fbbf24;--nbg:rgba(245,158,11,0.10);
  --gr:#10b981;--rd:#ef4444;--pu:#a78bfa;--cy:#22d3ee;
  --t1:#e8edf8;--t2:#8b96b8;--t3:#3d4f6e;
  --fh:'Syne',sans-serif;--fm:'JetBrains Mono',monospace;--fb:'Outfit',sans-serif;
  --sb:env(safe-area-inset-bottom,0px);--st:env(safe-area-inset-top,0px);
}
html,body{height:100%;overflow:hidden;background:var(--bg);}
body{font-family:var(--fb);font-size:14px;color:var(--t1);display:flex;flex-direction:column;position:fixed;width:100%;height:100%;}
::-webkit-scrollbar{width:3px;}::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:3px;}
.sc{position:absolute;inset:0;display:flex;flex-direction:column;background:var(--bg);transition:transform .28s cubic-bezier(.4,0,.2,1),opacity .28s;opacity:0;pointer-events:none;transform:translateY(20px);}
.sc.active{opacity:1;pointer-events:all;transform:none;}

/* SETUP SCREEN */
#sc-setup{align-items:center;justify-content:flex-start;padding:24px 20px;overflow-y:auto;}
.setup-logo{font-family:var(--fh);font-size:36px;font-weight:800;letter-spacing:-1px;margin-bottom:2px;margin-top:20px;}
.setup-logo span{color:var(--hb);}
.setup-sub{font-size:10px;letter-spacing:3px;color:var(--t2);text-transform:uppercase;margin-bottom:28px;}
.step-card{background:var(--s1);border:1px solid var(--bd);border-radius:16px;padding:16px;margin-bottom:12px;width:100%;max-width:480px;}
.step-num{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;background:var(--hb);color:#fff;font-size:11px;font-weight:700;font-family:var(--fm);margin-bottom:8px;}
.step-title{font-family:var(--fh);font-size:14px;font-weight:700;margin-bottom:4px;}
.step-body{font-size:12px;color:var(--t2);line-height:1.6;}
.step-body b{color:var(--t1);}
.step-body code{background:var(--s2);border:1px solid var(--bd2);border-radius:4px;padding:1px 6px;font-family:var(--fm);font-size:11px;color:var(--cy);}
.cfg-card{background:var(--s1);border:1.5px solid var(--hb);border-radius:16px;padding:16px;margin-bottom:12px;width:100%;max-width:480px;}
.cfg-title{font-family:var(--fh);font-size:15px;font-weight:700;color:var(--hb);margin-bottom:12px;}
.skip-note{font-size:11px;color:var(--t3);text-align:center;margin-top:8px;}

/* LOGIN */
#sc-login{align-items:center;justify-content:center;padding:28px;}
.ll{font-family:var(--fh);font-size:44px;font-weight:800;letter-spacing:-1.5px;margin-bottom:2px;}
.ll span{color:var(--hb);}
.lt{font-size:10px;letter-spacing:3px;color:var(--t2);text-transform:uppercase;margin-bottom:36px;}
.lc{background:var(--s1);border:1px solid var(--bd);border-radius:20px;padding:22px;width:100%;max-width:340px;}
.lhint{font-size:10px;color:var(--t3);margin-top:12px;text-align:center;}
.sync-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2);border-radius:8px;padding:4px 10px;font-size:10px;color:var(--gr);font-family:var(--fm);margin-top:10px;}

/* APP */
#sc-app{flex-direction:column;}
.tb{height:calc(54px + var(--st));padding-top:var(--st);background:var(--bg2);border-bottom:1px solid var(--bd);flex-shrink:0;}
.tbi{display:flex;align-items:center;justify-content:space-between;padding:0 14px 10px;height:54px;}
.tbl{font-family:var(--fh);font-size:17px;font-weight:800;letter-spacing:-.5px;}
.tbl span{color:var(--hb);}
.tbr{display:flex;align-items:center;gap:7px;}
.ck{background:var(--s1);border:1px solid var(--bd2);border-radius:20px;padding:4px 10px;font-family:var(--fm);font-size:11px;color:var(--hb);}
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(--gr);display:inline-block;margin-right:2px;}
.sync-dot.off{background:var(--rd);}
.sync-dot.wait{background:var(--nb);animation:bl 1s infinite;}

.pages{flex:1;overflow:hidden;position:relative;}
.pg{position:absolute;inset:0;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:14px 14px calc(72px + var(--sb));display:none;}
.pg.active{display:block;}
.bn{height:calc(58px + var(--sb));padding-bottom:var(--sb);background:var(--bg2);border-top:1px solid var(--bd);display:flex;flex-shrink:0;}
.bni{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;cursor:pointer;color:var(--t3);transition:color .15s;}
.bni.active{color:var(--hb);}
.bni-icon{font-size:19px;line-height:1;}
.bni-lbl{font-size:9px;font-weight:600;letter-spacing:.3px;text-transform:uppercase;}

/* CARDS */
.card{background:var(--s1);border:1px solid var(--bd);border-radius:14px;padding:14px;margin-bottom:11px;}
.ctitle{font-size:9px;text-transform:uppercase;letter-spacing:1.5px;color:var(--t2);margin-bottom:10px;font-family:var(--fm);}
.hero{background:linear-gradient(140deg,var(--s1),var(--s2));border:1px solid var(--bd2);border-radius:18px;padding:18px;margin-bottom:11px;position:relative;overflow:hidden;}
.hero::after{content:'';position:absolute;top:-50px;right:-40px;width:150px;height:150px;background:radial-gradient(circle,rgba(59,130,246,.1),transparent 70%);pointer-events:none;}
.hl{font-size:9px;letter-spacing:2px;color:var(--hb);text-transform:uppercase;margin-bottom:5px;font-family:var(--fm);}
.hbal{font-family:var(--fh);font-size:36px;font-weight:800;letter-spacing:-1px;line-height:1;}
.hsub{font-size:11px;color:var(--t2);margin-top:5px;}
.hbar-w{background:var(--s3);border-radius:5px;height:5px;margin-top:12px;overflow:hidden;}
.hbar{height:100%;border-radius:5px;transition:width .5s ease;}
.hmeta{display:flex;justify-content:space-between;margin-top:5px;font-size:9px;color:var(--t3);font-family:var(--fm);}
.lpill{display:inline-flex;align-items:center;gap:4px;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.18);border-radius:10px;padding:3px 8px;font-size:9px;color:var(--gr);font-family:var(--fm);}
.ldot{width:5px;height:5px;border-radius:50%;background:var(--gr);animation:bl 1.2s infinite;}
@keyframes bl{0%,100%{opacity:1}50%{opacity:.1}}
.sg{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:11px;}
.sc2{background:var(--s1);border:1px solid var(--bd);border-radius:13px;padding:13px;}
.slbl{font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--t2);margin-bottom:4px;font-family:var(--fm);}
.sval{font-family:var(--fm);font-size:19px;font-weight:600;line-height:1;}
.ssub{font-size:9px;color:var(--t3);margin-top:2px;}
.split{background:var(--s1);border:1px solid var(--bd);border-radius:14px;overflow:hidden;margin-bottom:11px;}
.split-hdr{padding:10px 14px;border-bottom:1px solid var(--bd);font-size:9px;text-transform:uppercase;letter-spacing:1.5px;color:var(--t2);font-family:var(--fm);}
.split-row{display:flex;align-items:center;padding:12px 14px;border-bottom:1px solid var(--bd);}
.split-row:last-of-type{border-bottom:none;}
.sdot{width:7px;height:7px;border-radius:50%;margin-right:9px;flex-shrink:0;}
.sname{font-size:12px;font-weight:500;flex:1;}
.sunits{font-family:var(--fm);font-size:11px;color:var(--t2);margin-right:10px;}
.sbill{font-family:var(--fm);font-size:13px;font-weight:600;}
.sbar{height:3px;display:flex;overflow:hidden;}
.sbar-h{background:var(--hb);}
.sbar-n{background:var(--nb);}
.btn{border:none;border-radius:10px;cursor:pointer;font-family:var(--fb);font-size:12px;font-weight:600;padding:9px 16px;transition:opacity .15s,transform .12s;display:inline-flex;align-items:center;gap:5px;justify-content:center;}
.btn:active{opacity:.8;transform:scale(.96);}
.btn-hb{background:var(--hb);color:#fff;}
.btn-nb{background:var(--nb);color:#111;}
.btn-gh{background:var(--s2);border:1px solid var(--bd2);color:var(--t2);}
.btn-rd{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.22);color:var(--rd);}
.btn-gr{background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.22);color:var(--gr);}
.btn-fw{width:100%;margin-top:7px;}
.btn-sm{padding:5px 11px;font-size:11px;}
.btn-ic{width:34px;height:34px;padding:0;border-radius:9px;}
.fg{margin-bottom:11px;}
.fl{font-size:9px;color:var(--t2);text-transform:uppercase;letter-spacing:1px;font-family:var(--fm);display:block;margin-bottom:4px;}
.fi{background:var(--s2);border:1.5px solid var(--bd2);border-radius:9px;color:var(--t1);font-family:var(--fb);font-size:13px;padding:10px 12px;outline:none;transition:border .18s;width:100%;}
.fi:focus{border-color:var(--hb);}
.fi::placeholder{color:var(--t3);}
select.fi option{background:var(--s2);}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.fsec{background:var(--s1);border:1px solid var(--bd);border-radius:12px;padding:12px;margin-bottom:10px;}
.fsec-t{font-size:10px;color:var(--t2);text-transform:uppercase;letter-spacing:1px;font-family:var(--fm);margin-bottom:10px;padding-bottom:7px;border-bottom:1px solid var(--bd);}
.sov{position:fixed;inset:0;background:rgba(0,0,0,.72);backdrop-filter:blur(5px);z-index:100;opacity:0;pointer-events:none;transition:opacity .22s;}
.sov.open{opacity:1;pointer-events:all;}
.sheet{position:fixed;bottom:0;left:0;right:0;background:var(--bg2);border-radius:18px 18px 0 0;border-top:1px solid var(--bd2);z-index:101;padding:0 0 calc(14px + var(--sb));max-height:91vh;overflow-y:auto;transform:translateY(100%);transition:transform .28s cubic-bezier(.4,0,.2,1);}
.sov.open .sheet{transform:none;}
.sh{width:34px;height:4px;background:var(--bd2);border-radius:4px;margin:11px auto 14px;}
.stitle{font-family:var(--fh);font-size:17px;font-weight:700;padding:0 18px 3px;}
.ssub2{font-size:11px;color:var(--t2);padding:0 18px 14px;}
.sbody{padding:0 14px;}
.sfooter{padding:10px 14px 0;display:flex;gap:7px;}
.li{background:var(--s1);border:1px solid var(--bd);border-radius:11px;padding:11px 12px;margin-bottom:7px;display:flex;gap:10px;align-items:flex-start;}
.li-ic{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.li-body{flex:1;min-width:0;}
.li-title{font-size:12px;font-weight:500;}
.li-sub{font-size:10px;color:var(--t2);margin-top:2px;}
.li-date{font-size:9px;color:var(--t3);font-family:var(--fm);margin-top:2px;}
.li-right{text-align:right;flex-shrink:0;}
.badge{display:inline-block;padding:2px 6px;border-radius:4px;font-size:8px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;}
.bh{background:rgba(59,130,246,.12);color:var(--hb);}
.bn2{background:rgba(245,158,11,.12);color:var(--nb);}
.bg{background:rgba(16,185,129,.12);color:var(--gr);}
.br{background:rgba(239,68,68,.12);color:var(--rd);}
.bp{background:rgba(167,139,250,.12);color:var(--pu);}
.ai2{background:var(--s1);border:1px solid var(--bd);border-radius:11px;padding:11px 12px;margin-bottom:7px;display:flex;align-items:center;gap:9px;}
.ai-em{width:34px;height:34px;border-radius:9px;background:var(--s2);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
.ai-info{flex:1;min-width:0;}
.ai-name{font-size:12px;font-weight:500;}
.ai-det{font-size:9px;color:var(--t2);margin-top:2px;font-family:var(--fm);}
.ai-kwh{font-family:var(--fm);font-size:10px;margin-top:2px;}
.owcard{background:linear-gradient(135deg,rgba(245,158,11,.08),rgba(245,158,11,.03));border:1.5px solid rgba(245,158,11,.22);border-radius:13px;padding:12px 14px;margin-bottom:11px;display:flex;align-items:center;justify-content:space-between;}
.ow-lbl{font-size:9px;color:var(--nb);text-transform:uppercase;letter-spacing:1px;font-family:var(--fm);margin-bottom:2px;}
.ow-amt{font-family:var(--fm);font-size:20px;font-weight:600;color:var(--nb);}
.ow-sub{font-size:10px;color:var(--t2);}
.qg{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:11px;}
.qbtn{background:var(--s2);border:1.5px solid var(--bd2);border-radius:11px;padding:11px 9px;cursor:pointer;transition:all .18s;}
.qbtn:active{transform:scale(.95);}
.qi{font-size:18px;margin-bottom:4px;}
.qn{font-size:10px;font-weight:600;color:var(--t1);}
.qk{font-family:var(--fm);font-size:9px;color:var(--hb);margin-top:2px;}
.htabs{display:flex;gap:5px;margin-bottom:11px;}
.htab{flex:1;padding:9px 6px;border-radius:11px;border:1.5px solid var(--bd);background:none;font-family:var(--fb);font-size:11px;font-weight:600;cursor:pointer;text-align:center;color:var(--t3);transition:all .18s;}.htab:not(.hb):not(.nb):not(.gr){color:var(--t3)!important;border-color:var(--bd)!important;background:none!important;}
.htab.hb{color:var(--hb);border-color:var(--hb);background:var(--hbg);}
.htab.nb{color:var(--nb);border-color:var(--nb);background:var(--nbg);}
.htab.gr{color:var(--gr);border-color:var(--gr);background:rgba(16,185,129,.08);}
.mnav{display:flex;align-items:center;gap:9px;margin-bottom:13px;}
.mnav button{background:var(--s2);border:1.5px solid var(--bd2);color:var(--t1);border-radius:9px;padding:6px 14px;cursor:pointer;font-size:17px;}
.mnav span{font-family:var(--fh);font-size:14px;font-weight:700;flex:1;text-align:center;}
.srow{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--bd);}
.srow:last-child{border-bottom:none;}
.sinfo h4{font-size:12px;font-weight:500;}
.sinfo p{font-size:10px;color:var(--t2);margin-top:1px;}
.shdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px;}
.stit{font-family:var(--fh);font-size:14px;font-weight:700;}
.oweit{background:var(--s1);border:1px solid var(--bd);border-radius:11px;padding:11px 12px;margin-bottom:7px;display:flex;justify-content:space-between;align-items:center;}
.ua{background:var(--s2);border:1.5px dashed var(--bd2);border-radius:11px;padding:18px;text-align:center;cursor:pointer;transition:all .18s;margin-bottom:9px;}
.ua:active{border-color:var(--hb);}
.ua input{display:none;}
#imgprev{width:100%;max-height:130px;object-fit:contain;border-radius:7px;margin-top:9px;display:none;}
.aipill{background:rgba(59,130,246,.07);border:1px solid rgba(59,130,246,.2);border-radius:7px;padding:7px 11px;font-size:10px;color:var(--hb);font-family:var(--fm);margin-bottom:9px;display:none;}
.bwo{display:flex;align-items:flex-end;gap:3px;}
.bc{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;}
.btr{width:100%;display:flex;align-items:flex-end;}
.bb{width:100%;border-radius:3px 3px 0 0;min-height:2px;transition:height .4s ease;}
.blbl{font-size:8px;color:var(--t3);font-family:var(--fm);}
.toast{position:fixed;bottom:calc(64px + var(--sb) + 10px);left:50%;transform:translateX(-50%) translateY(10px);background:var(--s2);border:1px solid var(--bd2);border-radius:9px;padding:9px 16px;font-size:11px;z-index:999;opacity:0;transition:all .22s;pointer-events:none;white-space:nowrap;max-width:88vw;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.toast.ok{border-color:rgba(16,185,129,.4);color:var(--gr);}
.toast.err{border-color:rgba(239,68,68,.4);color:var(--rd);}
.empty{text-align:center;padding:28px 16px;color:var(--t3);}
.empty-ic{font-size:32px;margin-bottom:7px;}

/* SYNC OVERLAY */
.sync-overlay{position:fixed;inset:0;background:rgba(10,14,26,.85);z-index:200;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;}
.sync-spinner{width:40px;height:40px;border:3px solid var(--bd2);border-top-color:var(--hb);border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
.sync-txt{font-family:var(--fm);font-size:12px;color:var(--t2);}
</style>
</head>
<body>

<!-- ===== SETUP SCREEN ===== -->
<div class="sc" id="sc-setup">
  <div class="setup-logo">Elec<span>Tracker</span></div>
  <div class="setup-sub">Firebase Already Configured ✅</div>

  <div class="step-card">
    <div class="step-num">1</div>
    <div class="step-title">Create a Free Firebase Project</div>
    <div class="step-body">
      Go to <b>console.firebase.google.com</b> and sign in with your Gmail.<br><br>
      Tap <b>"Add project"</b> → Name it <b>ElecTracker</b> → Disable Google Analytics → Click <b>"Create project"</b>.
    </div>
  </div>

  <div class="step-card">
    <div class="step-num">2</div>
    <div class="step-title">Enable Realtime Database</div>
    <div class="step-body">
      In your project, go to <b>Build → Realtime Database</b> → Click <b>"Create database"</b>.<br><br>
      Choose any location → Select <b>"Start in test mode"</b> → Click <b>Enable</b>.<br><br>
      Your database URL will look like: <code>https://electracker-xxxxx-default-rtdb.firebaseio.com</code>
    </div>
  </div>

  <div class="step-card">
    <div class="step-num">3</div>
    <div class="step-title">Get Your Web App Config</div>
    <div class="step-body">
      Go to <b>Project Settings</b> (gear icon ⚙️ top left) → Scroll down to <b>"Your apps"</b> → Click <b>&lt;/&gt; Web</b>.<br><br>
      Register app with nickname <b>ElecTracker</b> → You'll see a config block like:<br><br>
      <code>apiKey: "AIza..."</code><br>
      <code>authDomain: "..."</code><br>
      <code>databaseURL: "..."</code><br>
      <code>projectId: "..."</code><br>
      <code>appId: "..."</code><br><br>
      Copy and paste each value below 👇
    </div>
  </div>

  <div class="cfg-card">
    <div class="cfg-title">⚡ Paste Your Firebase Config</div>
    <div class="fg"><label class="fl">API Key</label><input class="fi" id="cfg-apikey" placeholder="AIzaSy..."></div>
