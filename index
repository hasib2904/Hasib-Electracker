// ===== CALCS =====
function calcBill(u){
  if(u<=0)return{energy:0,vat:0,total:0,rows:[]};
  let rem=u,prev=0,en=0,rows=[];
  for(const s of SLABS){
    if(rem<=0)break;
    const cap=s.to===Infinity?rem:Math.min(rem,s.to-prev);
    const cost=cap*s.r;en+=cost;
    rows.push({lbl:prev===0?`0–${s.to} kWh`:`${prev+1}–${s.to===Infinity?'∞':s.to} kWh`,u:cap,r:s.r,cost});
    rem-=cap;if(s.to!==Infinity)prev=s.to;
  }
  const vat=en*0.05;return{energy:en,vat,total:en+vat+84+40,rows};
}
function uFromT(t){
  if(t<=0)return 0;let rem=t,u=0,prev=0;
  for(const s of SLABS){const cap=s.to===Infinity?Infinity:(s.to-prev);const mc=cap===Infinity?rem:cap*s.r;const sp=Math.min(rem,mc);u+=sp/s.r;rem-=sp;if(rem<=0)break;if(s.to!==Infinity)prev=s.to;}
  return Math.max(0,u);
}
function dkwh(a){return a.watts*a.hours*(a.duty/100)/1000;}
function f(n,d=0){return(+n||0).toLocaleString('en-IN',{minimumFractionDigits:d,maximumFractionDigits:d});}
