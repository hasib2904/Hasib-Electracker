// ===== NEIGHBOR =====
function rNB(){
  const d=D();if(!d)return;
  const nn=d.nbName||'Neighbor';
  ['nb-tn','sp-nn','rpt-nn'].forEach(id=>{const e=document.getElementById(id);if(e)e.textContent=(id==='sp-nn'?'🏘️ ':'')+nn;});
  const n=new Date(),M=mp(n.getMonth(),n.getFullYear());
  const mR=d.readings.filter(r=>r.date.startsWith(M));
  const hU=mR.reduce((s,r)=>s+r.hk,0),nU=mR.reduce((s,r)=>s+r.nk,0),tU=hU+nU;
  const tB=calcBill(tU).total,ns=tU>0?nU/tU:0.5;
  const tnbB=d.readings.reduce((s,r)=>{const t=r.hk+r.nk;return s+calcBill(t).total*(t>0?r.nk/t:0);},0);
  const tpd=d.nbpay.reduce((s,p)=>s+p.amt,0),owed=Math.max(0,tnbB-tpd);
  document.getElementById('nb-mu').textContent=f(nU,1);document.getElementById('nb-mb').textContent='৳'+f(tB*ns,0);
  document.getElementById('nb-ow').textContent='৳'+f(owed,0);document.getElementById('nb-pd').textContent='৳'+f(tpd,0);
  const owEnt=d.readings.map(r=>{const t=r.hk+r.nk;return{date:r.date,bill:calcBill(t).total*(t>0?r.nk/t:0)};}).filter(e=>e.bill>0);
  document.getElementById('nb-owlist').innerHTML=
    (owEnt.length?owEnt.map(e=>`<div class="oweit"><div><div style="font-size:12px;font-weight:500">${fD(e.date)}</div><div style="font-size:10px;color:var(--t2)">Bill share</div></div><div style="font-family:var(--fm);font-size:13px;color:var(--nb)">৳${f(e.bill,0)}</div></div>`).join(''):'<div class="empty"><div>No neighbor readings yet</div></div>')+
    (d.nbpay.length?`<div class="ctitle" style="margin-top:12px;margin-bottom:7px">Payments Received</div>`+d.nbpay.map(p=>`<div class="oweit"><div><div style="font-size:12px;font-weight:500">${fD(p.date)}</div><div style="font-size:10px;color:var(--t2)">${p.note||'Payment'}</div></div><div style="display:flex;align-items:center;gap:7px;"><div style="font-family:var(--fm);font-size:13px;color:var(--gr)">+৳${f(p.amt,0)}</div><span class="badge bg">PAID</span><button class="btn btn-rd btn-sm" style="padding:3px 7px" onclick="delNBP(${p.id})">🗑</button></div></div>`).join(''):'');
  rApplList(d.nAppl,'nb-al','n','var(--nb)');
}
window.delNBP=async function(id){if(!confirm('Delete?'))return;const d=D();d.nbpay=d.nbpay.filter(p=>p.id!==id);renderAll();toast('Deleted');await pushToDB(d);};

// ===== HISTORY =====
function rHist(){
  const d=D();if(!d)return;
  document.getElementById('ht-rl').innerHTML=d.readings.length?d.readings.map(r=>`<div class="li"><div class="li-ic" style="background:var(--hbg)">📷</div><div class="li-body"><div class="li-title">৳ ${f(r.bal,2)}</div><div class="li-sub">🏠 ${f(r.hk,1)} kWh &nbsp;·&nbsp; 🏘️ ${f(r.nk,1)} kWh${r.note?' · '+r.note:''}</div><div class="li-date">${fD(r.date)}</div></div><div class="li-right"><span class="badge bh">READING</span><div style="margin-top:5px"><button class="btn btn-rd btn-sm" onclick="delR(${r.id})">🗑</button></div></div></div>`).join(''):'<div class="empty"><div class="empty-ic">📷</div><div>No readings yet</div></div>';
  document.getElementById('ht-tl').innerHTML=d.topups.length?d.topups.map(t=>`<div class="li"><div class="li-ic" style="background:rgba(16,185,129,.1)">💳</div><div class="li-body"><div class="li-title">+৳ ${f(t.amt,0)}</div><div class="li-sub">${t.note||'Recharge'}${t.ba?' · After: ৳'+f(t.ba,2):''}</div><div class="li-date">${fD(t.date)}</div></div><div class="li-right"><span class="badge bg">TOP-UP</span><div style="margin-top:5px"><button class="btn btn-rd btn-sm" onclick="delT(${t.id})">🗑</button></div></div></div>`).join(''):'<div class="empty"><div class="empty-ic">💳</div><div>No top-ups yet</div></div>';
  document.getElementById('ht-sl').innerHTML=d.sessions.length?d.sessions.map(s=>`<div class="li"><div class="li-ic" style="background:rgba(167,139,250,.1)">⚡</div><div class="li-body"><div class="li-title">${f(s.kwh,3)} kWh · ${s.min} min</div><div class="li-sub">${s.appl?.join(', ')||''}</div><div class="li-date">${fD(s.date)}</div></div><div class="li-right"><span class="badge bp">SESSION</span></div></div>`).join(''):'<div class="empty"><div class="empty-ic">⚡</div><div>No sessions</div></div>';
}
window.delR=async function(id){const d=D();d.readings=d.readings.filter(r=>r.id!==id);renderAll();toast('Deleted');await pushToDB(d);};
window.delT=async function(id){const d=D();d.topups=d.topups.filter(t=>t.id!==id);renderAll();toast('Deleted');await pushToDB(d);};

// ===== REPORTS =====
let rM=new Date().getMonth(),rY=new Date().getFullYear();
window.chM=function(x){rM+=x;if(rM>11){rM=0;rY++;}if(rM<0){rM=11;rY--;}rRpt();};
function rRpt(){
  const d=D();if(!d)return;
  document.getElementById('rpt-ml').textContent=FM[rM]+' '+rY;
  document.getElementById('rpt-yl').textContent=rY;if(!d)return;
  const M=mp(rM,rY);
  const mR=d.readings.filter(r=>r.date.startsWith(M)),mT=d.topups.filter(t=>t.date.startsWith(M));
  const hU=mR.reduce((s,r)=>s+r.hk,0),nU=mR.reduce((s,r)=>s+r.nk,0),tU=hU+nU;
  const {total,energy,vat,rows}=calcBill(tU),hs=tU>0?hU/tU:0.5,ns=1-hs;
  const hB=total*hs,nB=total*ns;
  document.getElementById('rpt-tb').textContent='৳'+f(total,0);
  document.getElementById('rpt-tu').textContent=`Total: ${f(tU,1)} kWh · Recharged: ৳${f(mT.reduce((s,t)=>s+t.amt,0),0)}`;
  document.getElementById('rpt-hu').textContent=f(hU,1)+' kWh';document.getElementById('rpt-nu').textContent=f(nU,1)+' kWh';
  document.getElementById('rpt-hb').textContent='৳'+f(hB,0);document.getElementById('rpt-nb2').textContent='৳'+f(nB,0);
  const hp=Math.round(hs*100);document.getElementById('rpt-bar').children[0].style.width=hp+'%';document.getElementById('rpt-bar').children[1].style.width=(100-hp)+'%';
  const se=document.getElementById('rpt-slabs');
  if(tU>0){se.innerHTML=`<div class="card" style="padding:11px 12px">`+rows.map(r=>`<div class="srow" style="padding:8px 0"><div class="sinfo"><h4>${r.lbl}</h4><p>৳${r.r}/kWh × ${f(r.u,1)} kWh</p></div><span style="font-family:var(--fm);font-size:12px;color:var(--nb)">৳${f(r.cost,0)}</span></div>`).join('')+`<div class="srow" style="padding:8px 0"><div class="sinfo"><h4>VAT 5% + Demand ৳84 + Meter ৳40</h4></div><span style="font-family:var(--fm);font-size:12px;color:var(--nb)">৳${f(vat+124,0)}</span></div><div style="border-top:1px solid var(--bd);padding-top:9px;margin-top:3px;display:flex;justify-content:space-between;align-items:center"><span style="font-weight:600;font-size:13px">Total Bill</span><span style="font-family:var(--fm);font-size:17px;color:var(--gr)">৳${f(total,0)}</span></div><div style="display:flex;justify-content:space-between;padding-top:5px;font-size:10px;color:var(--t2)"><span>🏠 Hasib: ৳${f(hB,0)}</span><span>🏘️ ${d.nbName||'Neighbor'}: ৳${f(nB,0)}</span></div></div>`;}
  else se.innerHTML='<div class="empty"><div>No readings this month</div></div>';
  const dim=new Date(rY,rM+1,0).getDate();
  drawC('rpt-dc',Array.from({length:dim},(_,i)=>{const ds=`${M}-${String(i+1).padStart(2,'0')}`;const show=[0,4,9,14,19,24,29].includes(i);return{l:show?String(i+1):'',v:d.readings.filter(r=>r.date===ds).reduce((s,r)=>s+r.hk+r.nk,0)};}),75,'var(--cy)');
  const yD=MO.map((m,i)=>{const yM=mp(i,rY);return{l:m,v:d.readings.filter(r=>r.date.startsWith(yM)).reduce((s,r)=>s+r.hk+r.nk,0)};});
  const yU=yD.reduce((s,x)=>s+x.v,0),yB=yD.reduce((s,x)=>s+calcBill(x.v).total,0);
  const yT=d.topups.filter(t=>t.date.startsWith(String(rY))).reduce((s,t)=>s+t.amt,0);
  const yP=yD.reduce((best,x)=>x.v>best.v?x:best,{v:0,l:'—'});
  document.getElementById('y-u').textContent=f(yU,1);document.getElementById('y-b').textContent='৳'+f(yB,0);
  document.getElementById('y-t').textContent='৳'+f(yT,0);document.getElementById('y-p').textContent=yP.l;
  drawC('y-ch',yD,75,'linear-gradient(0deg,var(--hb),var(--pu))');
}

// ===== CHART =====
function drawC(id,data,h,color){
  const el=document.getElementById(id);if(!el)return;
  const mx=Math.max(...data.map(x=>x.v),.01);
  el.innerHTML=data.map(x=>{const bh=Math.round(x.v/mx*h);return`<div class="bc" style="height:${h}px"><div class="btr" style="height:${h}px"><div class="bb" style="height:${bh}px;background:${color}"></div></div><div class="blbl">${x.l}</div></div>`;}).join('');
}

// ===== LOG ENTRY =====
function liHTML(e){
  if(e._t==='r')return`<div class="li"><div class="li-ic" style="background:var(--hbg)">📷</div><div class="li-body"><div class="li-title">৳ ${f(e.bal,2)}</div><div class="li-sub">🏠 ${f(e.hk,1)} kWh · 🏘️ ${f(e.nk,1)} kWh</div><div class="li-date">${fD(e.date)}</div></div><div class="li-right"><span class="badge bh">READING</span></div></div>`;
  if(e._t==='t')return`<div class="li"><div class="li-ic" style="background:rgba(16,185,129,.1)">💳</div><div class="li-body"><div class="li-title">+৳ ${f(e.amt,0)}</div><div class="li-sub">${e.note||'Recharge'}</div><div class="li-date">${fD(e.date)}</div></div><div class="li-right"><span class="badge bg">TOP-UP</span></div></div>`;
  return`<div class="li"><div class="li-ic" style="background:rgba(16,185,129,.1)">💚</div><div class="li-body"><div class="li-title">Neighbor paid ৳${f(e.amt,0)}</div><div class="li-sub">${e.note||'Payment received'}</div><div class="li-date">${fD(e.date)}</div></div><div class="li-right"><span class="badge bg">PAID</span></div></div>`;
}

